# Copy this file to ".env" for local reference.
# The application does not auto-load .env; export it manually:
#   set -a
#   source .env
#   set +a

# Security
API_KEY=dev-secret
RATE_LIMIT_PER_MIN=30

# Optional LLM enhancement for /v3/chat
OPENAI_API_KEY=

# Logging
LOG_LEVEL=INFO

# Optional v2 tuning
V2_SCORE_EXPERIMENT_PRESET=baseline
V2_QUERY_VARIANT_MERGE_STRATEGY=weighted_sum
V2_DISPLAY_SCORE_TEMPERATURE=1.0
V2_FUSION_DENSE_WEIGHT=0.7
V2_FUSION_LEXICAL_WEIGHT=0.3
